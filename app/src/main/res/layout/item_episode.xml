<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardEpisode"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutEpisode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Watched indicator -->
        <View
            android:id="@+id/viewWatchedIndicator"
            android:layout_width="8dp"
            android:layout_height="0dp"
            android:background="@color/episode_not_watched"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Episode code -->
        <TextView
            android:id="@+id/tvEpisodeCode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/checkboxSelected"
            app:layout_constraintStart_toEndOf="@id/viewWatchedIndicator"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="S01E01" />

        <!-- Episode name -->
        <TextView
            android:id="@+id/tvEpisodeName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/checkboxSelected"
            app:layout_constraintStart_toStartOf="@id/tvEpisodeCode"
            app:layout_constraintTop_toBottomOf="@id/tvEpisodeCode"
            tools:text="Pilot" />

        <!-- Air date -->
        <TextView
            android:id="@+id/tvAirDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="14sp"
            app:layout_constraintEnd_toStartOf="@id/checkboxSelected"
            app:layout_constraintStart_toStartOf="@id/tvEpisodeCode"
            app:layout_constraintTop_toBottomOf="@id/tvEpisodeName"
            tools:text="December 2, 2013" />

        <!-- Selection checkbox (only visible in selection mode) -->
        <CheckBox
            android:id="@+id/checkboxSelected"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
